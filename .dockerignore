# Keep the Docker build context lean and reproducible.
# Anything listed here is excluded from the image build.

# Version control & editor noise
.git
.gitignore
.gitattributes
.vscode
.idea
*.swp
.DS_Store

# Dependency / build outputs (re-created inside the image)
**/node_modules
**/dist
**/build
**/.next
**/.turbo
**/.cache
**/.parcel-cache
**/.vite

# Logs & runtime junk
**/*.log
**/npm-debug.log*
**/pnpm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/coverage
**/.nyc_output

# Local environment overrides — never bake secrets into the image
**/.env
**/.env.*
!**/.env.example

# Replit-specific tooling not needed at build time
.local
.upm
.replit
replit.nix
.config
.cache
attached_assets
.breakpoints

# Docker artifacts themselves
**/Dockerfile
**/docker-compose*.yml
**/.dockerignore
